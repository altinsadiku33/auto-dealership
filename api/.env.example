NODE_ENV=development
PORT=3001
DATABASE_URL="file:./prisma/auto.db"
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Sentry error tracking — required in staging/production
# Obtain from your Sentry project settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=auto-dealership-api
